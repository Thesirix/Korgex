
<TrackSoundButton>:
    background_normal: "images/sound_button_normal.png"
    background_down: "images/sound_button_down.png"
    bold: True
    font_size: dp(14)

<TrackRollButton>:
    background_normal: ''
    background_color: 0.10, 0.22, 0.18, 1
    color: 0.15, 0.85, 0.50, 1
    font_size: dp(10)
    bold: True

<TrackStepButton>:
    background_normal: "images/step_normal1.png"
    background_down: "images/step_down.png"

<TrackWidget>:
    size_hint_max_y: dp(72)
    size_hint_min_y: dp(42)
